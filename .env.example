# ========== 数据库 ==========
MYSQL_ROOT_PASSWORD=your_strong_password

# ========== AI 对话服务 ==========
# type=custom → 自定义服务（默认）, type=openai → DeepSeek 等
TEXTCHAT_API_TYPE=custom
TEXTCHAT_API_BASE_URL=http://your-ai-service:5000
TEXTCHAT_OPENAI_API_BASE_URL=https://api.deepseek.com
TEXTCHAT_OPENAI_API_KEY=sk-your-deepseek-key
TEXTCHAT_API_MODEL=deepseek-chat

# ========== 阿里云 DashScope (语音识别) ==========
DASHSCOPE_API_KEY=sk-your-dashscope-key

# ========== 高德天气 ==========
GAODE_WEATHER_API_KEY=your_amap_key

# ========== CDN（可选，部署时配置） ==========
APP_CDN_URL=https://cdn.your-domain.com
